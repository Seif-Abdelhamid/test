---
import { SEO } from '@wix/seo/components';
import { loadSEOTagsServiceConfig } from '@wix/seo/services';
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";
import "@wix/wix-vibe-plugins/plugins-vars.css";
import "@wix/wix-vibe-plugins/plugins-theme.css";
import "@/styles/global.css";

const seoTagsServiceConfig = await loadSEOTagsServiceConfig({
  pageUrl: Astro.url.href,
  itemData: {
    pageName: 'Home',
  },
});
---

<html lang="en" class="w-full h-full">
  <head>
    <Head />
    <SEO.Tags seoTagsServiceConfig={seoTagsServiceConfig} slot="seo-tags" />
    <!-- OMGyro custom CSS -->
    <link rel="stylesheet" href="/assets/css/global-overrides.css" />
    <link rel="stylesheet" href="/assets/css/header-unified.css" />
    <link rel="stylesheet" href="/assets/css/menu.css" />
    <link rel="stylesheet" href="/assets/css/rewards.css" />
    <link rel="stylesheet" href="/assets/css/gift-card.css" />
    <!-- OMGyro custom JS -->
    <script src="/assets/js/lenis-smooth.js" defer></script>
    <script src="/assets/js/mobile-panel.js" defer></script>
    <script src="/assets/js/sauce-bottle-fill.js" defer></script>
  </head>
  <body class="w-full h-full">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
